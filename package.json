{
  "name": "crawlertoll-cloudflare-template",
  "version": "0.1.0",
  "private": true,
  "description": "Fork-and-deploy Cloudflare Workers template for the AI-crawler economy. Detects AI crawlers, verifies Web Bot Auth, applies RSL 1.0 policy, and issues HTTP 402 with a structured payment offer — all at Cloudflare's edge, no Cloudflare Enterprise plan required.",
  "license": "Apache-2.0",
  "author": "Charthouse Ltd",
  "homepage": "https://crawlertoll.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/charthouse-ltd/crawlertoll-cloudflare-template.git"
  },
  "keywords": [
    "cloudflare-workers",
    "cloudflare",
    "ai-crawler",
    "pay-per-crawl",
    "web-bot-auth",
    "rsl-1.0",
    "http-402",
    "x402",
    "hono",
    "crawler-toll",
    "template"
  ],
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@crawlertoll/core": "^0.1.0",
    "@crawlertoll/hono": "^0.1.0",
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250109.0",
    "typescript": "^5.7.3",
    "wrangler": "^3.99.0"
  },
  "engines": {
    "node": ">=20"
  }
}
